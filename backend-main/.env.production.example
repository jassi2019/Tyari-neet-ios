# ═══════════════════════════════════════════════════════════
# Taiyari NEET Ki - Backend Production Environment Variables
# Copy this file to: backend-main/.env
# Fill in all values before deploying
# ═══════════════════════════════════════════════════════════

NODE_ENV=production

# ─────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────
# NOTE: DB_HOST will be overridden to "postgres" by docker-compose.prod.yml
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_NAME=education_app

# ─────────────────────────────────────────────
# JWT (Generate a long random string - never share)
# Generate: openssl rand -hex 64
# ─────────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_TO_LONG_RANDOM_STRING

# ─────────────────────────────────────────────
# Razorpay (Android Payments)
# Get from: https://dashboard.razorpay.com/app/keys
# ─────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_RhvQOAzK6nNUQm
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET_HERE

# ─────────────────────────────────────────────
# Apple IAP (iOS Payments)
# Get from: App Store Connect -> Your App -> In-App Purchases -> App-Specific Shared Secret
# ─────────────────────────────────────────────
APPLE_SHARED_SECRET=YOUR_APPLE_SHARED_SECRET_HERE
APPLE_BUNDLE_ID=com.taiyarineetki.educationapp

# ─────────────────────────────────────────────
# Email (OTP delivery)
# Gmail: enable 2FA -> App Passwords -> generate password
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=your-email@gmail.com
SMTP_TIMEOUT_MS=10000

# ─────────────────────────────────────────────
# Canva Integration (for topic content design URLs)
# Get from: https://www.canva.com/developers/apps
# ─────────────────────────────────────────────
CANVA_CLIENT_ID=YOUR_CANVA_CLIENT_ID
CANVA_CLIENT_SECRET=YOUR_CANVA_CLIENT_SECRET
CANVA_AUTH_REDIRECT_URI=https://api.taiyarineetki.com/api/v1/canva/oauth/redirect

# ─────────────────────────────────────────────
# Swagger API Docs
# ─────────────────────────────────────────────
SWAGGER_HOST=api.taiyarineetki.com

# ─────────────────────────────────────────────
# Developer Notifications (optional - comma separated emails)
# ─────────────────────────────────────────────
DEVELOPER_EMAILS=your-email@gmail.com

# ─────────────────────────────────────────────
# Dev/Test Settings
# ─────────────────────────────────────────────
ALLOW_DEV_OTP=false
